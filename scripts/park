#!/bin/zsh
set -euo pipefail

G=$'\033[0;32m' Y=$'\033[0;33m' R=$'\033[0;31m' C=$'\033[0;36m' N=$'\033[0m'
clean=false

while [[ $# -gt 0 ]]; do
    case "$1" in
        --clean|-c) clean=true; shift ;;
        *) echo "${R}âťŚ Unknown argument: $1${N}"; exit 1 ;;
    esac
done

worktree_dir=$(basename "$(git rev-parse --show-toplevel 2>/dev/null)") || {
    echo "${R}âťŚ Not in a git repository${N}"
    exit 1
}

# Determine the main worktree name to detect numbered variants
main_worktree=$(basename "$(cd "$(git rev-parse --git-common-dir)" && cd .. && pwd)")

if [[ "${worktree_dir:l}" == "${main_worktree:l}" ]]; then
    pl_branch="pl"
elif [[ "${worktree_dir:l}" =~ ^${main_worktree:l}([0-9]+)$ ]]; then
    pl_branch="pl${match[1]}"
else
    pl_branch="pl-$worktree_dir"
fi

# Remember the current branch for --clean
current_branch=$(git symbolic-ref --short HEAD 2>/dev/null || true)

echo "đź…żď¸Ź  Parking ${C}${worktree_dir}${N} â†’ ${C}${pl_branch}${N}"

# Create parking lot branch from main if it doesn't exist
if ! git show-ref --verify --quiet "refs/heads/$pl_branch"; then
    echo "đźŚ± Creating ${C}${pl_branch}${N} from main..."
    git checkout -b "$pl_branch" main || exit 1
else
    git checkout "$pl_branch" || exit 1
fi

# Fetch main and rebase
echo "đź“ˇ Fetching main..."
git fetch origin main 2>/dev/null && git merge-base --is-ancestor main origin/main && git update-ref refs/heads/main origin/main 2>/dev/null || echo "${Y}âš ď¸Ź  Fetch failed or main has local commits â€” rebasing against local main${N}"

echo "đź”„ Rebasing against main..."
if git rebase main; then
    echo "${G}âś… Parked on ${C}${pl_branch}${G} (rebased against main)${N}"
else
    git rebase --abort
    echo "${Y}âš ď¸Ź  Parked on ${C}${pl_branch}${Y} (rebase aborted due to conflicts)${N}"
fi

# Delete the original branch if --clean was specified
if $clean && [[ -n "$current_branch" && "$current_branch" != "$pl_branch" ]]; then
    echo "đź§ą Deleting branch ${C}${current_branch}${N}..."
    git branch -D "$current_branch"
fi

# Rename cmux workspace to indicate parked state
# CMUX_PARK_WS can be set externally (e.g. by refresh-workspaces) to specify the workspace ref,
# since cmux identify may return the focused workspace rather than the caller's after exec zsh.
ws="${CMUX_PARK_WS:-}"
if [[ -z "$ws" ]]; then
    identify=$(cmux identify 2>/dev/null || true)
    ws=$(echo "$identify" | grep -A5 '"caller"' | grep '"workspace_ref"' | head -1 | sed 's/.*"\(workspace:[0-9]*\)".*/\1/' || true)
    [[ -z "$ws" ]] && ws=$(echo "$identify" | grep '"workspace_ref"' | head -1 | sed 's/.*"\(workspace:[0-9]*\)".*/\1/' || true)
fi
if [[ -n "$ws" ]]; then
    if cmux rename-workspace --workspace "$ws" "Parked: ${worktree_dir}" &>/dev/null; then
        echo "đźŹ·ď¸Ź  Renamed workspace â†’ ${C}Parked: ${worktree_dir}${N}"
    else
        echo "${Y}âš ď¸Ź  Could not rename cmux workspace${N}"
    fi
fi

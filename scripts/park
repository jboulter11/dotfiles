#!/bin/zsh
set -euo pipefail

G=$'\033[0;32m' Y=$'\033[0;33m' R=$'\033[0;31m' C=$'\033[0;36m' N=$'\033[0m'
clean=false

while [[ $# -gt 0 ]]; do
    case "$1" in
        --clean|-c) clean=true; shift ;;
        *) echo "${R}❌ Unknown argument: $1${N}"; exit 1 ;;
    esac
done

worktree_dir=$(basename "$(git rev-parse --show-toplevel 2>/dev/null)") || {
    echo "${R}❌ Not in a git repository${N}"
    exit 1
}

# Determine the main worktree name to detect numbered variants
main_worktree=$(basename "$(cd "$(git rev-parse --git-common-dir)" && cd .. && pwd)")

if [[ "${worktree_dir:l}" == "${main_worktree:l}" ]]; then
    pl_branch="pl"
elif [[ "${worktree_dir:l}" =~ ^${main_worktree:l}([0-9]+)$ ]]; then
    pl_branch="pl${match[1]}"
else
    pl_branch="pl-$worktree_dir"
fi

# Remember the current branch for --clean
current_branch=$(git symbolic-ref --short HEAD 2>/dev/null || true)

echo "🅿️  Parking ${C}${worktree_dir}${N} → ${C}${pl_branch}${N}"

# Create parking lot branch from main if it doesn't exist
if ! git show-ref --verify --quiet "refs/heads/$pl_branch"; then
    echo "🌱 Creating ${C}${pl_branch}${N} from main..."
    git checkout -b "$pl_branch" main || exit 1
else
    git checkout "$pl_branch" || exit 1
fi

# Fetch main and rebase
echo "📡 Fetching main..."
git fetch origin main 2>/dev/null && git merge-base --is-ancestor main origin/main && git update-ref refs/heads/main origin/main 2>/dev/null || echo "${Y}⚠️  Fetch failed or main has local commits — rebasing against local main${N}"

echo "🔄 Rebasing against main..."
if git rebase main; then
    echo "${G}✅ Parked on ${C}${pl_branch}${G} (rebased against main)${N}"
else
    git rebase --abort
    echo "${Y}⚠️  Parked on ${C}${pl_branch}${Y} (rebase aborted due to conflicts)${N}"
fi

# Delete the original branch if --clean was specified
if $clean && [[ -n "$current_branch" && "$current_branch" != "$pl_branch" ]]; then
    echo "🧹 Deleting branch ${C}${current_branch}${N}..."
    git branch -D "$current_branch"
fi

# Rename cmux workspace to indicate parked state
ws=$(cmux identify --no-caller 2>/dev/null | grep '"workspace_ref"' | head -1 | sed 's/.*"\(workspace:[0-9]*\)".*/\1/' || true)
if [[ -n "$ws" ]]; then
    if cmux rename-workspace --workspace "$ws" "Parked: ${worktree_dir}" &>/dev/null; then
        echo "🏷️  Renamed workspace → ${C}Parked: ${worktree_dir}${N}"
    else
        echo "${Y}⚠️  Could not rename cmux workspace${N}"
    fi
fi

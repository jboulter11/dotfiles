#!/bin/bash
set -euo pipefail

C=$'\033[0;36m' R=$'\033[0;31m' N=$'\033[0m'

run_cmux() {
    local output
    if ! output=$(cmux "$@" 2>&1); then
        echo "  ${R}❌ cmux $1 failed: ${output}${N}" >&2
        return 1
    fi
}

find_surface() {
    local ws_ref="$1" match_type="$2"
    local tree surface title
    tree=$(cmux tree --workspace "$ws_ref" 2>/dev/null)

    local candidates=()
    while IFS= read -r sline; do
        surface=$(echo "$sline" | grep -o 'surface:[0-9]*')
        [[ -z "$surface" ]] && continue
        title=$(echo "$sline" | sed 's/.*\] "//' | sed 's/" .*//')

        # Lazygit is easy to identify
        if [[ "$title" == *lazygit* ]] || [[ "$title" == "lg" ]]; then
            continue
        fi
        candidates+=("$surface")
    done <<< "$(echo "$tree" | grep 'surface:')"

    # Among non-lazygit surfaces, check screen for claude's status bar (📂)
    for surface in "${candidates[@]}"; do
        local screen
        screen=$(cmux read-screen --workspace "$ws_ref" --surface "$surface" --lines 3 2>/dev/null || true)
        local is_claude=false
        if echo "$screen" | grep -q '📂'; then
            is_claude=true
        fi

        case "$match_type" in
            claude) if $is_claude; then echo "$surface"; return; fi ;;
            terminal) if ! $is_claude; then echo "$surface"; return; fi ;;
        esac
    done
}

reshell() {
    local ws_ref="$1"
    local surface
    surface=$(find_surface "$ws_ref" terminal)
    [[ -z "$surface" ]] && return

    run_cmux send --workspace "$ws_ref" --surface "$surface" "exec zsh" || return
    run_cmux send-key --workspace "$ws_ref" --surface "$surface" Enter || return
    echo "  🔄 Re-shelled terminal"
}

repark() {
    local ws_ref="$1"

    local surface
    surface=$(find_surface "$ws_ref" terminal)
    [[ -z "$surface" ]] && return

    run_cmux send --workspace "$ws_ref" --surface "$surface" "git symbolic-ref --short HEAD 2>/dev/null | grep -qE '^pl([0-9]+$|-|$)' && CMUX_PARK_WS=$ws_ref park; clear" || return
    run_cmux send-key --workspace "$ws_ref" --surface "$surface" Enter || return
    echo "  🅿️  Re-parked (if on pl branch)"
}

restart_claude() {
    local ws_ref="$1"

    local surface
    surface=$(find_surface "$ws_ref" claude)
    [[ -z "$surface" ]] && return

    local status
    status=$(cmux list-status --workspace "$ws_ref" 2>/dev/null)
    if echo "$status" | grep -q 'claude_code=Running'; then
        echo "  ⏭️  Claude busy, skipping"
        return
    fi

    # Check if claude is idle via status or screen (list-status isn't always populated)
    local idle=false
    if echo "$status" | grep -q 'claude_code='; then
        idle=true
    else
        local screen
        screen=$(cmux read-screen --workspace "$ws_ref" --surface "$surface" --lines 3 2>/dev/null)
        if echo "$screen" | grep -q '^❯'; then
            idle=true
        fi
    fi

    if $idle; then
        run_cmux send --workspace "$ws_ref" --surface "$surface" "/exit" || return
        run_cmux send-key --workspace "$ws_ref" --surface "$surface" Enter || return
        sleep 1
        run_cmux send --workspace "$ws_ref" --surface "$surface" "claude --continue" || return
        run_cmux send-key --workspace "$ws_ref" --surface "$surface" Enter || return
        echo "  🤖 Restarted claude with --continue"
    else
        echo "  💤 Claude not detected"
    fi
}

while IFS= read -r line; do
    ws_ref=$(echo "$line" | grep -o 'workspace:[0-9]*')
    ws_name=$(echo "$line" | sed 's/.*workspace:[0-9]* *//' | sed 's/ *\[selected\].*//')
    [[ -z "$ws_ref" ]] && continue

    echo "${C}${ws_name}${N} (${ws_ref})"
    reshell "$ws_ref"
    repark "$ws_ref"
    restart_claude "$ws_ref"
done <<< "$(cmux list-workspaces 2>/dev/null | grep 'workspace:')"
